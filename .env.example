# LearnMateAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./learnmate.db
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Seed / Mock Data Account Passwords ───────────────────────────────────────
# These are used ONLY by seed_mock_data.py to create demo test accounts.
# Set to any value you like; they will be bcrypt-hashed before being stored.
