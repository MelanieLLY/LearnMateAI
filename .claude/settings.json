{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "WriteFile",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Claude Code] File saved. Remember to run linter! (HW grading hook)'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Please remember to run /chat-history-log before you exit!'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ $COMMAND == *'git commit'* ]]; then echo '[Claude Code] C.L.E.A.R Framework reminder. (HW grading hook)'; fi; exit 0"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(uvicorn:*)",
      "Bash(alembic:*)",
      "Edit(server/src/**)",
      "Write(server/src/**)",
      "Edit(server/tests/**)",
      "Write(server/tests/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)"
    ],
    "deny": [
      "Edit(.env)",
      "Write(.env)",
      "Edit(node_modules/**)",
      "Write(node_modules/**)",
      "Edit(.git/**)",
      "Write(.git/**)"
    ]
  }
}
