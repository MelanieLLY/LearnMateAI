{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "WriteFile",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Claude Code] File saved. Remember to run linter! (HW grading hook)'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Please remember to run /chat-history-log before you exit!'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); if echo \"$INPUT\" | grep -q 'git commit'; then echo '🛑 [STOP HOOK] Tests must pass before commit! Run: cd server && pytest' >&2; exit 2; else exit 0; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(uvicorn:*)",
      "Bash(alembic:*)",
      "Edit(server/src/**)",
      "Write(server/src/**)",
      "Edit(server/tests/**)",
      "Write(server/tests/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)"
    ],
    "deny": [
      "Edit(.env)",
      "Write(.env)",
      "Edit(node_modules/**)",
      "Write(node_modules/**)",
      "Edit(.git/**)",
      "Write(.git/**)"
    ]
  }
}
